---
const categories = [
  { name: 'Alimentatie Sanatoasa', slug: 'alimentatie-sanatoasa' },
  { name: 'Fitness Acasa', slug: 'fitness-acasa' },
  { name: 'Cosmetice Naturale', slug: 'cosmetice-naturale' },
  { name: 'Casa Eco Friendly', slug: 'casa-eco-friendly' },
  { name: 'Remedii Naturiste', slug: 'remedii-naturiste' }
];

const legalPages = [
  { name: 'Politica de Confidentialitate', slug: 'privacy-policy' },
  { name: 'Termeni si Conditii', slug: 'terms' },
  { name: 'Politica Cookies', slug: 'cookies' }
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-logo-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 20h10"/>
              <path d="M10 20c5.5-2.5.8-6.4 3-10"/>
              <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/>
              <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>
            </svg>
          </span>
          GreenCert
        </a>
        <p class="footer-description">
          Resursa ta de incredere pentru un stil de viata sanatos si ecologic. Descoperim impreuna cele mai bune produse naturale, sfaturi de nutritie si practici sustenabile.
        </p>
      </div>

      <div class="footer-column">
        <h4>Categorii</h4>
        <ul class="footer-links">
          {categories.map(cat => (
            <li><a href={`/${cat.slug}/`}>{cat.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-column">
        <h4>Legal</h4>
        <ul class="footer-links">
          {legalPages.map(page => (
            <li><a href={`/${page.slug}/`}>{page.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-column">
        <h4>Navigare</h4>
        <ul class="footer-links">
          <li><a href="/">Acasa</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/sitemap/">Sitemap</a></li>
          <li><a href="https://ofertatelefoane.ro/">ofertatelefoane.ro</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} GreenCert. Toate drepturile rezervate.</p>
    </div>
  </div>
</footer>
