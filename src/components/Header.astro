---
const categories = [
  { name: 'Alimentatie Sanatoasa', slug: 'alimentatie-sanatoasa' },
  { name: 'Fitness Acasa', slug: 'fitness-acasa' },
  { name: 'Cosmetice Naturale', slug: 'cosmetice-naturale' },
  { name: 'Casa Eco Friendly', slug: 'casa-eco-friendly' },
  { name: 'Remedii Naturiste', slug: 'remedii-naturiste' }
];
---

<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 20h10"/>
            <path d="M10 20c5.5-2.5.8-6.4 3-10"/>
            <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/>
            <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>
          </svg>
        </span>
        <span class="logo-text">GreenCert</span>
      </a>

      <nav class="main-nav">
        {categories.map(cat => (
          <a href={`/${cat.slug}/`} class="nav-link">{cat.name}</a>
        ))}
      </nav>

      <button class="mobile-menu-toggle" aria-label="Meniu" onclick="toggleMobileMenu()">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <nav class="mobile-nav" id="mobileNav">
      {categories.map(cat => (
        <a href={`/${cat.slug}/`} class="mobile-nav-link">{cat.name}</a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  function toggleMobileMenu() {
    const toggle = document.querySelector('.mobile-menu-toggle');
    const nav = document.getElementById('mobileNav');
    toggle.classList.toggle('active');
    nav.classList.toggle('active');
  }

  // Add scroll effect to header
  window.addEventListener('scroll', () => {
    const header = document.querySelector('.site-header');
    if (window.scrollY > 50) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  });
</script>
