---
import ArticleCard from './ArticleCard.astro';

interface Article {
  title: string;
  slug: string;
  excerpt: string;
  image: string;
  category: string;
  categorySlug: string;
  date: string;
}

interface Props {
  currentSlug: string;
  currentCategory: string;
  articles: Article[];
}

const { currentSlug, currentCategory, articles } = Astro.props;

// Filter articles from same category, exclude current, sort by date, take 3
const similarArticles = articles
  .filter(a => a.categorySlug === currentCategory && a.slug !== currentSlug)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
---

{similarArticles.length > 0 && (
  <section class="similar-articles">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Articole similare</h2>
        <a href={`/${currentCategory}/`} class="section-link">
          Vezi toate
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline; vertical-align: middle; margin-left: 4px;">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="articles-grid">
        {similarArticles.map(article => (
          <ArticleCard
            title={article.title}
            slug={article.slug}
            excerpt={article.excerpt}
            image={article.image}
            category={article.category}
            categorySlug={article.categorySlug}
            date={article.date}
            showExcerpt={false}
          />
        ))}
      </div>
    </div>
  </section>
)}
