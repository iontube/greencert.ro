---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Uleiul de cocos ma ajuta sa slabesc?", answer: "Uleiul de cocos contine trigliceride cu lant mediu (MCTs) care pot stimula metabolismul si oferi o senzatie de satietate. Cu toate acestea, este o grasime bogata in calorii si nu este o solutie magica pentru slabit. Trebuie integrat intr-o dieta echilibrata si un stil de viata activ pentru a vedea rezultate, si consumat cu moderatie." },
    { question: "Pot folosi ulei de cocos pe fata?", answer: "Da, uleiul de cocos poate fi un demachiant excelent si un hidratant natural pentru fata, mai ales pentru pielea uscata. Totusi, pentru unele persoane cu ten gras sau predispus la acnee, poate fi comedogenic (poate infunda porii). Recomand sa testezi pe o zona mica inainte de a-l aplica pe toata fata." },
    { question: "Care e diferenta dintre uleiul de cocos virgin si cel rafinat?", answer: "Uleiul de cocos virgin este presat la rece din pulpa proaspata, pastrandu-si aroma, gustul si nutrientii. Cel rafinat este obtinut din copra uscata, procesat la temperaturi ridicate si dezodorizat, pierzand gustul si o parte din nutrienti, dar avand un punct de fum mai ridicat. Cel virgin e mai bun pentru consum crud si cosmetice, cel rafinat pentru gatit la temperaturi mai inalte." },
    { question: "Cum ar trebui sa pastrez uleiul de cocos?", answer: "Uleiul de cocos se pastreaza intr-un loc racoros si intunecat, la temperatura camerei, ferit de lumina directa a soarelui. Nu este necesar sa-l tii la frigider. Se va solidifica sub 24-25 de grade Celsius si se va lichefia deasupra acestei temperaturi, ceea ce este un proces normal si nu afecteaza calitatea sau proprietatile sale." },
    { question: "Pot gati cu ulei de cocos?", answer: "Da, se poate gati cu ulei de cocos. Varianta virgin este ideala pentru soteuri rapide, copt sau adaugat in preparate crude, oferind o aroma placuta. Varianta rafinata are un punct de fum mai ridicat, fiind mai potrivita pentru gatit la temperaturi medii spre ridicate, dar nu este cel mai bun ulei pentru prajit adanc. Alege in functie de metoda de gatit." },
    { question: "Este uleiul de cocos mai bun decat uleiul de masline?", answer: "Uleiul de cocos si uleiul de masline sunt ambele sanatoase, dar au profile nutritionale si utilizari diferite. Uleiul de cocos este bogat in MCTs, bun pentru energie si cosmetice. Uleiul de masline (extra virgin) este bogat in grasimi mononesaturate si antioxidanti, excelent pentru salate si gatit la temperaturi joase. Nu e vorba de 'mai bun', ci de 'diferit' si 'potrivit' pentru diverse scopuri." }
];

const formattedDate = new Date("2026-02-04T15:10:01.672Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

