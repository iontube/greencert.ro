---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Ce ceaiuri sunt bune pentru copii pentru a le intari imunitatea?", answer: "Pentru copii, cele mai bune ceaiuri sunt cele blande si cu gust placut. Macesele sunt excelente datorita vitaminei C. Teiul este calmant si ajuta la somn, iar musetelul e bun pentru digestie si relaxare. Socul poate fi folosit cu masura, mai ales la raceli. Evita ceaiurile puternice sau stimulente, consulta un pediatru inainte de a introduce ceaiuri noi in dieta copiilor." },
    { question: "Pot sa beau ceaiuri pentru imunitate zilnic?", answer: "Da, multe ceaiuri blande, cum ar fi cel de macese, tei sau menta, pot fi consumate zilnic. E chiar recomandat pentru a mentine un nivel constant de suport. Pentru ceaiuri mai puternice, precum echinaceea, e bine sa le consumi in cure scurte, de 1-2 saptamani, urmate de o pauza. Variatia e cheia, alterneaza tipurile de ceaiuri." },
    { question: "Cat timp dureaza pana vad efecte de la ceaiurile pentru imunitate?", answer: "Nu te astepta la efecte imediate. Ceaiurile pentru imunitate functioneaza pe termen lung, prin sustinerea constanta a corpului. Beneficiile se acumuleaza in timp, odata cu un consum regulat. Vei observa o rezistenta mai buna la boli si o stare generala de bine dupa cateva saptamani sau luni de consum consistent, nu dupa cateva zile." },
    { question: "Pot combina mai multe ceaiuri pentru a le spori efectele?", answer: "Da, poti combina ceaiuri, si chiar e o idee buna pentru a beneficia de proprietatile diverse ale plantelor. De exemplu, macesele cu soc si ghimbir fac o combinatie excelenta. Asigura-te ca plantele sunt compatibile si ca nu ai contraindicatii. Incepe cu combinatii simple si asculta cum reactioneaza corpul tau la ele." },
    { question: "Ceaiurile calde ajuta la raceala?", answer: "Absolut! Ceaiurile calde sunt un remediu excelent in caz de raceala. Ele hidrateaza corpul, calmeaza gatul iritat si ajuta la decongestionarea cailor respiratorii. Plante precum ghimbirul, menta sau socul au proprietati care amelioreaza simptomele. In plus, caldura si aroma ceaiului au un efect reconfortant, ajutandu-te sa te simti mai bine." },
    { question: "Ceaiurile vrac sunt mai bune decat cele la plic?", answer: "De cele mai multe ori, da. Ceaiurile vrac, cu frunze intregi sau bucati mari de plante, sunt considerate superioare. Ele sunt mai putin procesate, isi pastreaza mai bine aromele si compusii activi. Ceaiurile la plic, mai ales cele ieftine, contin adesea praf de plante, de o calitate inferioara. Investitia in ceai vrac de calitate merita pe deplin." }
];

const formattedDate = new Date("2026-01-15T09:17:31.000Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

