---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Este sigur sa aplic ulei esential de lavanda direct pe piele?", answer: "Nu, in general nu e recomandat sa aplici uleiul esential de lavanda nediluat direct pe piele. Desi e considerat bland, poate provoca iritatii, mai ales pe pielea sensibila. Intotdeauna dilueaza-l intr-un ulei purtator (cum ar fi uleiul de cocos sau jojoba) inainte de aplicare. O dilutie de 1-3% este de obicei sigura pentru adulti." },
    { question: "Pot folosi ulei de lavanda pentru copii sau bebelusi?", answer: "Da, uleiul esential de lavanda poate fi folosit pentru copii, dar cu precautie maxima si dilutie mult mai mare. Pentru bebelusi, se recomanda o dilutie de 0.25-0.5%, iar pentru copii mai mari, 0.5-1%. Consulta un specialist in aromaterapie sau medicul pediatru inainte de utilizare, mai ales pentru copiii sub 2 ani. Aplica-l pe talpi sau pe spate, niciodata pe fata." },
    { question: "Uleiul de lavanda ajuta la somn?", answer: "Da, uleiul esential de lavanda este renumit pentru proprietatile sale calmante si relaxante, care pot contribui la un somn mai bun. Inhalarea mirosului de lavanda, prin difuzor sau prin aplicarea diluata pe perna, ajuta la reducerea anxietatii si la instalarea unei stari de liniste, facilitand adormirea si imbunatatind calitatea somnului." },
    { question: "Ce ar trebui sa caut pe eticheta unui ulei de lavanda de calitate?", answer: "Pe eticheta unui ulei de lavanda de calitate ar trebui sa gasesti '100% ulei esential de lavanda', denumirea botanica (Lavandula angustifolia), metoda de extractie (distilare cu abur) si tara de origine. Evita produsele etichetate 'ulei parfumat' sau 'esenta'. Certificarile organice sunt un plus pentru a garanta puritatea si calitatea." },
    { question: "Pot ingera ulei esential de lavanda?", answer: "Nu, in general nu se recomanda ingerarea uleiurilor esentiale fara sfatul si supravegherea unui specialist calificat in aromaterapie clinica sau a unui medic. Uleiurile esentiale sunt extrem de concentrate si pot fi toxice daca sunt ingerate incorect. Este mult mai sigur si la fel de eficient sa folosesti lavanda prin inhalare sau aplicare topica diluata." },
    { question: "Cum pastrez corect uleiul esential de lavanda?", answer: "Pentru a-i mentine proprietatile, pastreaza uleiul esential de lavanda intr-o sticla de sticla inchisa la culoare (maro sau albastru inchis), intr-un loc racoros si ferit de lumina directa a soarelui. Asigura-te ca dopul este bine inchis dupa fiecare utilizare pentru a preveni oxidarea si evaporarea. In aceste conditii, isi va pastra calitatile timp de 2-3 ani." }
];

const formattedDate = new Date("2026-02-03T13:20:12.510Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

