---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa un borcan de miere de Manuka in Romania?", answer: "Un borcan de 250g de miere de Manuka in Romania costa intre 80-100 lei pentru variantele UMF 5+ (MGO 83+) si poate depasi 400-500 lei pentru cele cu UMF 20+ (MGO 829+). Pretul variaza in functie de concentratia de MGO/UMF si brand." },
    { question: "Care e diferenta intre mierea de Manuka UMF si MGO?", answer: "UMF (Unique Manuka Factor) este un sistem de clasificare mai complex, care testeaza mai multi compusi (MGO, leptosperin, DHA), oferind o garantie mai larga a autenticitatii si calitatii mierii de Manuka. MGO (Metilglioxal) masoara doar concentratia principala a compusului antibacterian, fiind un indicator direct al puterii terapeutice, mai usor de inteles." },
    { question: "Merita sa cumperi miere de Manuka cu UMF mic, de exemplu UMF 5+?", answer: "Da, mierea de Manuka UMF 5+ merita pentru intretinere generala, un boost usor de imunitate si ca indulcitor sanatos, avand un pret mai accesibil, in jur de 90-120 lei/250g. Nu este la fel de puternica pentru afectiuni serioase, dar ofera beneficii de baza si este o optiune buna pentru a te familiariza cu produsul." },
    { question: "De ce e mierea de Manuka asa scumpa?", answer: "Mierea de Manuka este scumpa din mai multe motive: este produsa exclusiv in Noua Zeelanda, cantitatea este limitata, procesul de recoltare si certificare este riguros, iar proprietatile sale antibacteriene si antiinflamatorii unice ii confera o valoare terapeutica ridicata. Costurile de productie si testare contribuie semnificativ la pretul final." },
    { question: "Cum stiu daca mierea de Manuka e autentica?", answer: "Pentru a verifica autenticitatea mierii de Manuka, cauta pe eticheta o certificare UMF sau MGO cu o cifra clara, verifica originea (Noua Zeelanda) si asigura-te ca produsul provine de la un brand reputabil. Multe branduri ofera certificate de analiza pentru fiecare lot, pe care le poti solicita." },
    { question: "Cum se pastreaza corect mierea de Manuka?", answer: "Mierea de Manuka se pastreaza corect la temperatura camerei, intr-un loc racoros si uscat, ferita de lumina directa a soarelui. Asigura-te ca borcanul este bine inchis dupa fiecare utilizare pentru a preveni oxidarea si contaminarea. Nu necesita refrigerare, iar pastrarea in conditii optime ii mentine proprietatile pe termen lung." },
    { question: "Pot folosi mierea de Manuka pentru copii?", answer: "Da, mierea de Manuka poate fi folosita pentru copii, dar numai dupa varsta de 1 an, din cauza riscului de botulism infantil. Pentru copiii mici, se recomanda concentratii UMF mai mici (5+ sau 10+) si un dozaj de o jumatate de lingurita pe zi, pentru a sustine imunitatea sau a calma durerile in gat." },
    { question: "Unde gasesc miere de Manuka de incredere in Romania?", answer: "Mierea de Manuka de incredere poate fi gasita in farmacii mari (ex: Catena, Dr. Max), magazine naturiste specializate (online si fizice), si pe platforme online cunoscute care colaboreaza direct cu importatori autorizati. Verifica intotdeauna reputatia vanzatorului si certificarea produsului inainte de a cumpara." }
];

const formattedDate = new Date("2026-03-01T10:59:07.199Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

