---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa becurile LED economice pentru casa in Romania?", answer: "Un bec LED economic decent costa intre 15 si 35 de lei in Romania, in functie de brand, putere si caracteristici. Exista optiuni mai ieftine, sub 15 lei, dar si modele premium sau smart, care pot depasi 50-100 de lei." },
    { question: "Care e diferenta intre becurile LED si cele economice clasice (CFL)?", answer: "Becurile LED sunt mult mai eficiente energetic, consumand pana la 50% mai putin decat CFL-urile, au o durata de viata de 2-3 ori mai mare (15.000-25.000 ore vs 6.000-10.000 ore) si nu contin mercur toxic, fiind mai sigure si mai ecologice." },
    { question: "Merita sa schimb toate becurile vechi cu LED-uri?", answer: "Da, merita pe deplin sa schimbi toate becurile vechi cu LED-uri. Vei reduce consumul de energie cu 80-90% fata de becurile incandescente si cu 50% fata de CFL-uri, amortizand investitia in mai putin de un an si bucurandu-te de o durata de viata mult mai lunga." },
    { question: "Ce putere (W) ar trebui sa aiba un bec LED pentru o camera normala?", answer: "Pentru o camera normala de 15-20 mp, cum ar fi un dormitor sau living, un bec LED de 8-10W este suficient, echivalentul unui bec incandescent de 60-75W. Pentru spatii mai mici sau ca lumina de accent, 5-7W sunt de ajuns." },
    { question: "De ce palpaie uneori becurile LED?", answer: "Palpairea becurilor LED poate fi cauzata de dimmere incompatibile, fluctuatii de tensiune in reteaua electrica, sau de calitatea slaba a becului in sine. Asigura-te ca folosesti becuri LED \"dimmable\" cu un dimmer compatibil, sau ca reteaua electrica este stabila." },
    { question: "Cum sa aleg lumina potrivita (calda/rece) pentru fiecare camera?", answer: "Alege lumina calda (2700K-3000K) pentru relaxare in dormitor, living sau hol. Foloseste lumina neutra (4000K) pentru bucatarie sau birou, unde ai nevoie de claritate. Lumina rece (5000K-6500K) este potrivita pentru spatii de lucru intense sau garaj." },
    { question: "Unde gasesc becuri LED economice de calitate in Romania?", answer: "Becuri LED economice de calitate pot fi gasite in magazinele mari de bricolaj (Dedeman, Leroy Merlin, Hornbach), in supermarketuri (Kaufland, Carrefour), in magazinele online (eMAG, evoMAG) si la magazine specializate in iluminat, precum si la IKEA." },
    { question: "Cat timp tin in medie becurile LED?", answer: "In medie, becurile LED au o durata de viata de 15.000 pana la 25.000 de ore. Asta se traduce prin 10 pana la 20 de ani de utilizare, la o medie de 3-4 ore de functionare pe zi, depasind cu mult becurile incandescente sau halogene." }
];

const formattedDate = new Date("2026-03-04T10:52:39.915Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

