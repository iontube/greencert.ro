---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa o bicicleta fitness pentru acasa decenta?", answer: "O bicicleta fitness pentru acasa decenta, cu o volanta de minim 6-8 kg si rezistenta magnetica, costa in general intre 1000 si 2500 RON. Modelele sub 1000 RON sunt adesea pliabile si mai putin robuste, potrivite pentru utilizare ocazionala, in timp ce cele peste 2500 RON ofera functii premium si confort sporit." },
    { question: "Care e diferenta majora intre o bicicleta fitness verticala si una recumbent?", answer: "Diferenta majora consta in pozitia corpului: pe o bicicleta fitness verticala stai drept, ca pe o bicicleta normala, iar pe una recumbent (orizontala) stai pe un scaun cu spatar, intr-o pozitie semi-intinsa, cu pedalele in fata. Modelul recumbent reduce presiunea pe spate si articulatii, fiind ideal pentru confort sau recuperare." },
    { question: "Merita sa investesc intr-o bicicleta fitness pentru acasa mai scumpa?", answer: "Da, de cele mai multe ori merita. O bicicleta fitness pentru acasa mai scumpa (peste 1500 RON) ofera o constructie mai robusta, o volanta mai grea pentru o pedalare fluida, un confort sporit al scaunului si adesea programe de antrenament mai variate sau conectivitate smart. Aceste caracteristici contribuie la o experienta de utilizare mai placuta si la o durabilitate mai mare a aparatului." },
    { question: "Ce probleme frecvente pot sa apara la o bicicleta fitness pentru acasa?", answer: "Problemele frecvente includ zgomote (scartaituri, trosnituri), in special la modelele mai ieftine cu volanta usoara sau rezistenta mecanica, slabirea suruburilor, display-uri care se defecteaza sau senzori de puls imprecisi. De asemenea, scaunul poate deveni inconfortabil dupa utilizare prelungita, necesitand o perna suplimentara." },
    { question: "Cum intretin corect o bicicleta fitness pentru acasa ca sa ma tina mult?", answer: "Pentru a intretine corect o bicicleta fitness pentru acasa, sterge-o de transpiratie dupa fiecare utilizare cu o laveta umeda, verifica periodic suruburile si strange-le daca e cazul, si lubrifiaza (daca e cazul) partile mobile conform instructiunilor producatorului. Pastreaz-o intr-un loc ferit de umezeala excesiva si praf." },
    { question: "De ce e importanta greutatea maxima suportata la o bicicleta fitness pentru acasa?", answer: "Greutatea maxima suportata este cruciala deoarece indica robustetea si stabilitatea constructiei bicicletei. Daca greutatea utilizatorului depaseste limita specificata, aparatul se poate deteriora rapid, poate deveni instabil sau chiar periculos. Este recomandat sa alegi o bicicleta ce suporta cu 10-20 kg mai mult decat greutatea ta actuala." },
    { question: "Unde gasesc cele mai bune oferte la biciclete fitness pentru acasa in Romania?", answer: "Cele mai bune oferte pentru biciclete fitness pentru acasa in Romania le gasesti la retaileri online specializati in echipamente sportive (ex: Sportisimo, Decathlon, Hervis), la magazinele mari de electronice si electrocasnice (ex: eMAG, Altex) sau direct pe site-urile importatorilor. Urmareste perioadele de reduceri (Black Friday, lichidari de stoc) pentru preturi mai bune." },
    { question: "Pot slabi eficient cu o bicicleta fitness pentru acasa?", answer: "Da, poti slabi eficient cu o bicicleta fitness pentru acasa, dar succesul depinde de consistenta antrenamentelor si de o alimentatie echilibrata. Prin pedalare regulata (minim 3-4 ori pe saptamana, 30-60 de minute) la o intensitate moderata spre ridicata, poti arde intre 300 si 600 de calorii pe ora, contribuind semnificativ la deficitul caloric necesar pentru slabire." }
];

const formattedDate = new Date("2026-02-10T15:10:01.726Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

