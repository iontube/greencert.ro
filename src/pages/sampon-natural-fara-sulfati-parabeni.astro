---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa un sampon natural fara sulfati parabeni in Romania?", answer: "Un sampon natural fara sulfati parabeni in Romania costa, in medie, intre 25 si 70 de lei. Pretul variaza in functie de brand, cantitate si certificari, cele mai accesibile fiind in jur de 25-30 lei pentru 250ml, iar cele premium depasind 60-70 lei." },
    { question: "Care e diferenta intre sampon natural si sampon bio?", answer: "Diferenta principala e data de certificari: un sampon \"bio\" (sau organic) contine un procent minim de ingrediente organice certificate (de obicei peste 95% din ingredientele vegetale), in timp ce un sampon \"natural\" poate contine ingrediente derivate natural fara a fi neaparat certificate organic. Samponul bio are standarde mai stricte de productie si puritate." },
    { question: "Merita sa trec la sampon natural fara sulfati parabeni?", answer: "Da, merita sa treci la sampon natural fara sulfati parabeni, mai ales daca ai scalpul sensibil, par uscat, vopsit sau deteriorat. Eliminarea sulfatilor si parabenilor reduce iritatiile, mentine hidratarea naturala a parului si scalpului, si protejeaza culoarea, ducand la un par mai sanatos pe termen lung." },
    { question: "Ce sampon natural e mai bun pentru par gras?", answer: "Pentru parul gras, cel mai bun sampon natural fara sulfati parabeni contine ingrediente precum argila, extract de urzica, menta, rozmarin sau arbore de ceai. Acestea ajuta la reglarea excesului de sebum si la purificarea scalpului, fara a-l usca excesiv. Cauta variante specifice pentru \"par gras\" sau \"purifiant\"." },
    { question: "De ce nu face spuma multa un sampon natural?", answer: "Un sampon natural fara sulfati parabeni nu face spuma multa pentru ca ii lipsesc sulfatii (SLS/SLES), agentii spumanti agresivi. Spuma este doar o chestiune de marketing, nu are legatura directa cu eficienta curatarii. O spuma fina si cremoasa este suficienta pentru a curata parul eficient." },
    { question: "Cum sa aleg un sampon natural fara sulfati parabeni pentru par vopsit?", answer: "Pentru par vopsit, alege un sampon natural fara sulfati parabeni cu formule blande, hidratante, care contin uleiuri vegetale (argan, jojoba), unt de shea sau extracte de plante cu rol protector. Acestea ajuta la mentinerea intensitatii culorii si previn uscarea parului, care e adesea accentuata de vopsire." },
    { question: "Unde gasesc sampon natural fara sulfati parabeni bun in Romania?", answer: "Poti gasi un sampon natural fara sulfati parabeni bun in farmacii (Klorane, Gerovital), supermarketuri mari (Gerovital, Botanicals, Organic Shop), magazine naturiste (online si fizice), si pe site-uri dedicate produselor cosmetice bio. Verifica intotdeauna lista de ingrediente (INCI) inainte de achizitie." },
    { question: "Cat dureaza pana se obisnuieste parul cu samponul natural?", answer: "Perioada de adaptare a parului la un sampon natural fara sulfati parabeni, cunoscuta si ca \"detox\", dureaza in general intre 2 si 4 saptamani. In acest timp, scalpul isi regleaza productia de sebum, iar parul elimina reziduurile acumulate de la produsele conventionale. Fii rabdator si rezultatele vor aparea." }
];

const formattedDate = new Date("2026-02-06T15:10:02.028Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

