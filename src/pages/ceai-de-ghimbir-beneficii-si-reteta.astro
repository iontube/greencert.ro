---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat de des pot bea ceai de ghimbir?", answer: "Poti bea 1-3 cani pe zi, in functie de cum te simti si de concentratia ceaiului. E bine sa asculti corpul si sa nu exagerezi, mai ales daca esti sensibil la stomac. O cana dimineata si una seara sunt o rutina placuta si benefica pentru multi oameni care cauta un plus de vitalitate si o digestie mai buna." },
    { question: "Pot femeile insarcinate sa bea ceai de ghimbir?", answer: "Da, ghimbirul e adesea recomandat pentru ameliorarea greturilor matinale. Totusi, e esential sa vorbesti cu medicul tau inainte, pentru ca fiecare sarcina e diferita si cantitatile trebuie adaptate. In general, cantitati moderate sunt considerate sigure, dar prudenta e intotdeauna cea mai buna abordare in sarcina." },
    { question: "Care sunt principalele beneficii ale ceaiului de ghimbir?", answer: "Ghimbirul e un aliat de nadejde pentru digestie, ajuta la calmarea starilor de greata si are proprietati antiinflamatoare naturale. E un bun prieten in sezonul rece, oferind o senzatie de caldura si sprijinind sistemul imunitar. De asemenea, poate reduce disconfortul muscular si contribuie la o stare generala de bine." },
    { question: "Pot folosi ghimbir pudra in loc de ghimbir proaspat pentru ceai?", answer: "Da, poti folosi ghimbir pudra, dar retine ca e mai putin potent si gustul poate fi diferit. Ai nevoie de o cantitate mai mica (cam 1/4 lingurita de pudra la o cana) si asigura-te ca e ghimbir pur, fara aditivi. Cel proaspat e mereu prima optiune pentru mine, pentru ca e mai vibrant si mai eficient." },
    { question: "Cum fac ceaiul de ghimbir mai putin picant?", answer: "Pentru un gust mai bland, foloseste mai putin ghimbir sau taie-l in felii mai mari, in loc sa-l razi. Poti adauga mai multa apa sau sa-l fierbi pentru un timp mai scurt. Un strop de miere sau o felie de lamaie pot, de asemenea, sa echilibreze iuteala si sa-l faca mai placut pentru papilele gustative." },
    { question: "Exista efecte secundare la ceaiul de ghimbir?", answer: "In general, e bine tolerat. Unele persoane pot experimenta arsuri la stomac sau disconfort gastric daca beau prea mult sau ceai prea concentrat. De asemenea, ghimbirul poate interactiona cu medicamente anticoagulante, asa ca e bine sa consulti un specialist daca iei astfel de tratamente sau ai afectiuni preexistente." }
];

const formattedDate = new Date("2026-02-03T15:10:02.074Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

