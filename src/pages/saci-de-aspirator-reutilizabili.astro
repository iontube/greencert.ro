          <tr><td>Sac Aspirator Reutilizabil Karcher WD Series</td><td>Industrial/Umed-Uscat</td><td>-</td><td>-</td><td>-</td><td>-</td></tr>
          <tr><td>Sac Reutilizabil Aspirator Philips PowerPro Compact</td><td>Specific</td><td>-</td><td>-</td><td>-</td><td>-</td></tr>
          </tbody>
