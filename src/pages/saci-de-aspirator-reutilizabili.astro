---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa saci de aspirator reutilizabili?", answer: "Pretul pentru sacii de aspirator reutilizabili variaza intre ~50 si ~85 lei pentru o singura bucata. Un set de doi saci cu filtrare HEPA poate ajunge la ~120 lei. Desi initial sunt mai scumpi decat cei de unica folosinta, investitia se amortizeaza in cateva luni, avand in vedere ca un sac reutilizabil rezista pana la 1-2 ani." },
    { question: "Sunt sacii reutilizabili mai buni decat cei de unica folosinta?", answer: "Da, sacii reutilizabili sunt considerati mai buni pe termen lung. Ei reduc semnificativ deseurile, contribuind la un mediu mai curat. In plus, materialele textile de calitate superioara ofera adesea o filtrare mai buna a prafului decat sacii de hartie, mentinand un aer mai curat in casa. Economia financiara este un alt avantaj major." },
    { question: "Cum se curata sacii de aspirator reutilizabili?", answer: "Dupa ce golesti sacul de praf, il poti scutura energic afara, intr-un loc ferit de vant. Pentru o curatare mai profunda, majoritatea sacilor textili pot fi spalati manual cu apa rece si putin detergent. Unii saci permit si spalarea la masina, la un program delicat, la temperaturi scazute (sub 30°C). Este esential sa-l lasi sa se usuce complet inainte de a-l refolosi, pentru a preveni aparitia mirosurilor neplacute sau a mucegaiului." },
    { question: "Sacii reutilizabili afecteaza puterea de aspirare?", answer: "In general, sacii reutilizabili de calitate, fabricati din materiale textile dense, nu ar trebui sa afecteze semnificativ puterea de aspirare. Dimpotriva, o filtrare superioara poate chiar imbunatati calitatea aerului evacuat. Este important sa cureti sacul regulat; un sac incarcat cu praf sau murdar poate reduce fluxul de aer si, implicit, eficienta aspiratorului." },
    { question: "Pot folosi un sac universal in loc de unul specific?", answer: "Da, poti folosi un sac universal, dar cu anumite precautii. Sacii universali vin cu un adaptor si cleme de fixare, menite sa se potriveasca la mai multe modele de aspiratoare. Asigura-te ca fixarea este etansa si ca sacul nu este prea mare sau prea mic pentru compartimentul aspiratorului tau. Desi sunt o solutie convenabila, un sac specific modelului tau va oferi intotdeauna cea mai buna potrivire si performanta." }
];

const formattedDate = new Date("2026-03-09T11:07:03.755Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout
