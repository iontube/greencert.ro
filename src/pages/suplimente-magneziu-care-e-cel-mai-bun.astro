---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa un supliment de magneziu bun?", answer: "Un supliment de magneziu bun poate costa intre 40 si 180 de lei pe luna, in functie de forma si brand. De exemplu, un magneziu citrat de calitate costa in jur de 40-70 de lei, in timp ce un magneziu bisglicinat e undeva la 60-120 de lei, iar cel L-treonat poate ajunge la 150-180 de lei." },
    { question: "Care e diferenta intre magneziu citrat si bisglicinat?", answer: "Diferenta majora sta in absorbtie si efecte secundare. Magneziul bisglicinat are o absorbtie superioara si este bland cu stomacul, fiind ideal pentru relaxare si somn, fara efecte laxative. Magneziul citrat are o absorbtie buna si un efect laxativ, fiind recomandat pentru constipatie, dar poate provoca diaree la doze mari." },
    { question: "Merita sa iau magneziu L-treonat pentru memorie?", answer: "Da, magneziul L-treonat merita luat pentru imbunatatirea memoriei si a functiei cognitive, deoarece este singura forma de magneziu care traverseaza eficient bariera hemato-encefalica. Este mai scump, costand in jur de 150-180 de lei pe luna, dar este specific conceput pentru sanatatea creierului." },
    { question: "Ce forma de magneziu e mai buna pentru somn?", answer: "Pentru somn, cea mai buna forma de magneziu este bisglicinatul, datorita absorbtiei sale excelente si a faptului ca glicina, aminoacidul de care este legat, are proprietati calmante. Se recomanda o doza de 200-400 mg de magneziu elementar, luata cu aproximativ o ora inainte de culcare." },
    { question: "De ce ma doare stomacul de la magneziu?", answer: "Stomacul te poate durea de la magneziu, mai ales de la forme slab absorbite precum oxidul de magneziu sau de la doze prea mari de citrat, deoarece acestea pot irita tractul digestiv si pot avea un efect laxativ puternic. Incearca o forma mai blanda, cum ar fi bisglicinatul, si ia-l cu mancare." },
    { question: "Cum stiu daca am deficit de magneziu?", answer: "Simptomele comune ale deficitului de magneziu includ crampe musculare, oboseala cronica, insomnie, anxietate, migrene si batai neregulate ale inimii. Desi analizele de sange pentru magneziu seric nu sunt intotdeauna concludente, o combinatie de simptome si o dieta saraca in magneziu pot indica o deficienta." },
    { question: "Unde gasesc suplimente de magneziu de calitate?", answer: "Suplimente de magneziu de calitate pot fi gasite in farmacii mari (Dr. Max, Sensiblu), magazine de produse naturiste (Plafar, Remedium), si online pe site-uri specializate (Vegis, Vitamix, Plantum). Cauta branduri cu reputatie buna si certificari de calitate, cum ar fi Solgar, Now Foods, Life Extension sau Biotech USA." },
    { question: "Pot lua magneziu zilnic fara probleme?", answer: "Da, majoritatea oamenilor pot lua magneziu zilnic fara probleme, respectand doza recomandata de 300-400 mg de magneziu elementar pentru adulti. Este un mineral esential, iar deficienta este comuna. Totusi, in cazul unor afectiuni renale sau daca iei alte medicamente, este esential sa consulti medicul inainte de a incepe suplimentarea." }
];

const formattedDate = new Date("2026-02-08T15:10:01.689Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

