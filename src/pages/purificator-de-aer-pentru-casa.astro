---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa un purificator de aer bun pentru casa?", answer: "Un purificator de aer pentru casa bun, care sa isi faca treaba, costa intre 600 si 1500 RON. Modelele de baza incep de la 500-700 RON, iar cele cu performante medii si functii smart ajung la 1000-1500 RON. Exista si optiuni premium de peste 2000 RON, dar pentru majoritatea, un model de 800-1200 RON e suficient." },
    { question: "Care e diferenta intre un purificator de aer si un dezumidificator?", answer: "Un purificator de aer pentru casa filtreaza particulele din aer (praf, polen, alergeni) si elimina mirosurile cu ajutorul filtrelor HEPA si de carbon activ. Un dezumidificator, in schimb, extrage excesul de umiditate din aer pentru a preveni mucegaiul si condensul. Sunt doua aparate cu functii total diferite, desi ambele contribuie la un mediu interior mai sanatos." },
    { question: "Merita sa cumperi un purificator de aer daca nu ai alergii?", answer: "Da, merita sa cumperi un purificator de aer pentru casa chiar daca nu ai alergii. Aerul din interior contine praf, matreata de animale, spori de mucegai, virusuri si compusi organici volatili care pot afecta sanatatea pe termen lung. Un purificator imbunatateste calitatea generala a aerului, reducand riscul de iritatii respiratorii si mentinand un mediu mai proaspat." },
    { question: "Ce purificator de aer e mai bun pentru o camera mare?", answer: "Pentru o camera mare (peste 50 mp), e mai bun un purificator de aer pentru casa cu un CADR (Clean Air Delivery Rate) cat mai ridicat, de minim 300-400 m³/h. Modele precum Philips 2000i/3000i Series sau Xiaomi Mi Air Purifier Pro sunt optiuni bune, asigurand o filtrare eficienta si rapida a intregului volum de aer." },
    { question: "De ce miroase ciudat purificatorul de aer nou?", answer: "Un purificator de aer pentru casa nou poate mirosi ciudat initial din cauza materialelor plastice sau a filtrelor noi, mai ales cele cu carbon activ. Acest miros ar trebui sa dispara in cateva ore sau zile de functionare. Daca persista sau e un miros puternic de ozon, verifica filtrele sau contacteaza producatorul, e posibil sa fie o problema." },
    { question: "Cum se intretine un purificator de aer pentru casa?", answer: "Intretinerea unui purificator de aer pentru casa implica in principal curatarea pre-filtrului lavabil (o data pe luna, prin aspirare sau spalare) si schimbarea filtrelor HEPA si de carbon activ conform indicatiilor producatorului, de obicei la fiecare 6-12 luni. E important sa folosesti filtre originale pentru a mentine eficienta si a prelungi durata de viata a aparatului." },
    { question: "Unde gasesc filtre de schimb originale pentru purificatorul meu?", answer: "Filtre de schimb originale pentru purificatorul de aer pentru casa gasesti de obicei la magazinele online de electronice (eMAG, Altex, Flanco), pe site-urile oficiale ale producatorilor (Xiaomi, Philips, Blueair) sau la distribuitorii autorizati. Recomand sa verifici si magazinele specializate in electrocasnice mici, care adesea au o gama mai variata de consumabile." },
    { question: "Ce inseamna un purificator de aer 'eco-friendly'?", answer: "Un purificator de aer pentru casa 'eco-friendly' inseamna, in general, un aparat cu un consum redus de energie (clasa energetica buna), fabricat din materiale reciclabile sau durabile si care foloseste filtre eficiente pe termen lung, reducand astfel frecventa inlocuirii. Unele modele au si un mod 'eco' care optimizeaza functionarea pentru un consum minim." }
];

const formattedDate = new Date("2026-02-22T15:10:01.753Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

