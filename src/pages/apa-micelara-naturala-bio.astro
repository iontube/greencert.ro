---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa o apa micelara naturala bio buna?", answer: "O apa micelara naturala bio de calitate costa, in general, intre 35 si 90 de lei pentru un flacon de 200-250 ml. Pretul variaza in functie de brand, certificari si ingrediente, dar poti gasi optiuni excelente in jurul valorii de 50-70 de lei." },
    { question: "Care e diferenta intre apa micelara naturala si cea conventionala?", answer: "Diferenta majora sta in ingrediente: cea naturala foloseste extracte vegetale, hidrolati si tenside blande, certificate organic, fara chimicale iritante sau parfumuri sintetice. Cea conventionala contine adesea conservanti agresivi, parfumuri artificiale si agenti de curatare mai puternici, care pot irita pielea pe termen lung." },
    { question: "Merita sa investesc intr-o apa micelara bio certificata?", answer: "Da, merita pe deplin. Certificarile (precum ECOCERT, COSMOS ORGANIC) garanteaza ca produsul respecta standarde stricte privind ingredientele organice, procesul de fabricatie si impactul asupra mediului. E o garantie a calitatii si a faptului ca produsul e cu adevarat natural si sigur pentru piele." },
    { question: "Cum stiu daca o apa micelara e cu adevarat naturala?", answer: "Verifica lista de ingrediente (INCI): cauta hidrolati (ape florale) la inceputul listei, extracte vegetale si tenside blande, derivate din plante. Cel mai sigur indicator este insa prezenta unei certificari organice recunoscute, cum ar fi ECOCERT sau COSMOS ORGANIC, afisata vizibil pe ambalaj." },
    { question: "De ce e important sa clatesc fata dupa ce folosesc apa micelara?", answer: "Chiar daca unele produse \"no rinse\", e esential sa clatesti fata dupa folosirea apei micelare. Micelii, agentii de curatare, pot lasa reziduuri pe piele care, pe termen lung, pot bloca porii, irita tenul sau pot impiedica absorbtia eficienta a produselor de ingrijire aplicate ulterior." },
    { question: "Unde gasesc apa micelara naturala bio in Romania?", answer: "Poti gasi apa micelara naturala bio in magazinele online specializate pe produse bio si naturale, in farmacii naturiste, in drogherii mari cu sectiuni dedicate produselor organice, sau chiar in supermarketuri mari care au o gama extinsa de cosmetice bio. Cauta branduri precum Sanoflore, Avril, Melvita, Lavera sau Cattier." },
    { question: "Apa micelara bio expira repede?", answer: "Apele micelare bio au, in general, o durata de valabilitate similara cu cele conventionale, undeva intre 6 si 12 luni de la deschidere (indicata de simbolul PAO - Period After Opening). Datorita conservantilor naturali, pot avea o durata de viata putin mai scurta decat cele cu conservanti sintetici puternici, dar nu \"expira repede\" in sensul ca ar strica la cateva saptamani." },
    { question: "E ok sa folosesc apa micelara naturala pe ten sensibil?", answer: "Absolut, apa micelara naturala bio este, de cele mai multe ori, o alegere excelenta pentru tenul sensibil. Formulele sale blande, bazate pe hidrolati si extracte calmante (precum albastrele, musetel sau aloe vera), minimizeaza riscul de iritatii. Cauta produse special formulate pentru ten sensibil si verifica mereu lista de ingrediente pentru a evita potentialii alergeni." }
];

const formattedDate = new Date("2026-02-26T10:00:01.592Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
