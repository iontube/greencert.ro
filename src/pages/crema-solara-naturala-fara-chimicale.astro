---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa o crema solara naturala fara chimicale in Romania?", answer: "Pretul unei creme solare naturale fara chimicale in Romania variaza, in general, intre 50 RON si 250 RON, depinzand de brand, SPF si cantitate. Poti gasi optiuni decente la 70-120 RON pentru un tub de 50-100ml." },
    { question: "Care e diferenta intre cremele solare minerale si cele chimice?", answer: "Cremele solare minerale (naturale) folosesc oxid de zinc si dioxid de titan pentru a reflecta razele UV de pe piele, actionand ca o bariera fizica. Cremele chimice absorb razele UV si le transforma in caldura, avand ingrediente precum Oxybenzone, care pot fi absorbite in organism." },
    { question: "Merita sa cumpar o crema solara naturala, chiar daca e mai scumpa?", answer: "Da, merita investitia. Cremele solare naturale sunt considerate mai sigure pentru sanatatea pielii si a mediului, reducand riscul de iritatii, alergii si impactul negativ asupra recifurilor de corali. Beneficiile pe termen lung justifica adesea pretul mai ridicat." },
    { question: "Ce SPF e mai bun pentru o crema solara naturala?", answer: "Un SPF intre 30 si 50 este ideal pentru o protectie adecvata in majoritatea situatiilor, atat pentru fata, cat si pentru corp. Un SPF mai mare de 50 ofera o protectie marginal mai buna, dar nu dubla, si poate da o falsa senzatie de siguranta." },
    { question: "De ce lasa crema solara naturala o pelicula alba pe piele?", answer: "Pelicula alba este cauzata de oxidul de zinc si dioxidul de titan, care sunt minerale albe si formeaza o bariera fizica la suprafata pielii. Formulele moderne, in special cele cu particule non-nano, sunt insa mult mai rafinate si reduc semnificativ acest efect." },
    { question: "Cum sa aplic corect o crema solara naturala ca sa ma protejeze?", answer: "Aplic-o generos, folosind aproximativ o lingurita pentru fata si gat, si un shot glass (30ml) pentru corp. Reaplic-o la fiecare doua ore, sau imediat dupa inot, transpiratie intensa sau stergere cu prosopul, pentru a mentine protectia optima." },
    { question: "Unde gasesc creme solare naturale fara chimicale autentice?", answer: "Le gasesti in farmacii naturiste, magazine online specializate in produse bio si ecologice, si in anumite plafaruri sau drogherii cu sectiuni dedicate. Cauta branduri cu certificari recunoscute precum ECOCERT sau Natrue pentru autenticitate." },
    { question: "Cat timp tine o crema solara naturala odata deschisa?", answer: "Odata deschisa, o crema solara naturala are, de obicei, o perioada de valabilitate de 6 pana la 12 luni. Verifica simbolul 'PAO' (Period After Opening) de pe ambalaj, care arata un borcanel deschis cu o cifra si litera 'M' (ex: 6M, 12M)." }
];

const formattedDate = new Date("2026-03-03T10:52:56.652Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

