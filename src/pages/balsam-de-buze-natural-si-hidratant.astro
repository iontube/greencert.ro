---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa un balsam de buze natural si hidratant bun?", answer: "Un balsam de buze natural si hidratant de calitate costa, in general, intre 10 si 30 de lei. Preturile variaza in functie de brand, certificari bio si ingrediente. De exemplu, poti gasi optiuni eficiente la 10-15 lei, dar si produse premium la 25-30 de lei." },
    { question: "Care e diferenta intre un balsam de buze natural si unul obisnuit?", answer: "Diferenta majora consta in ingrediente. Un balsam natural foloseste unturi si uleiuri vegetale, miere si ceara de albine pentru hidratare si reparare. Cel obisnuit contine adesea parafina, petrolatum, silicon, parfumuri sintetice si parabeni, care pot crea o dependenta si nu hranesc in profunzime." },
    { question: "Merita sa cumpar un balsam de buze cu certificare bio?", answer: "Da, merita sa cumperi un balsam cu certificare bio. Aceste certificari (precum ECOCERT, NATRUE) garanteaza ca produsul contine ingrediente naturale sau organice si ca respecta standarde stricte de productie, fara chimicale daunatoare. Iti ofera incredere in calitatea si puritatea produsului." },
    { question: "Cat de des ar trebui sa aplic un balsam de buze natural?", answer: "Aplica un balsam de buze natural ori de cate ori simti nevoia, mai ales cand buzele sunt uscate sau expuse la vant si frig. In general, 3-5 aplicari pe zi sunt suficiente. Pentru buze foarte crapate, poti aplica un strat mai gros seara, inainte de culcare." },
    { question: "Ce ingrediente naturale sunt cele mai bune pentru buze crapate?", answer: "Pentru buze crapate, cele mai bune ingrediente naturale sunt untul de shea, mierea, propolisul, uleiul de ricin si uleiul de jojoba. Acestea au proprietati reparatoare, cicatrizante si hidratante intense, ajutand la refacerea barierei pielii si calmarea iritatiilor." }
];

const formattedDate = new Date("2026-03-08T10:48:33.438Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout
  title="Balsam de buze natural si hidratant - GreenCert"
  description="Daca esti in cautarea unui balsam de buze natural si hidratant care sa-ti repare buzele crapate si sa le mentina catifelate, ai nimerit bine. Am testat o gramada de optiuni in ultimii ani, de la branduri cunoscute la mici producatori romani, si am adunat aici ce e mai bun, pe bune."
  image="/images/articles/balsam-de-buze-natural-si-hidratant.webp"
  type="article"
  publishedTime="2026-03-08T10:48:33.438Z"
  modifiedTime="2026-03-08T10:48:33.438Z"
  author="Alexandra Florea"
  faq={faq}
>
  <article>
    <header class="article-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">Acasa</a>
          <span class="breadcrumb-separator">/</span>
          Cosmetice Naturale
          <span class="breadcrumb-separator">/</span>
          <span>Balsam de buze natural si hidratant</span>
        </nav>

        <div class="article-meta">
          <span class="article-category-badge">Cosmetice Naturale</span>
          <span class="article-date">{formattedDate}</span>
        </div>

        <h1 class="article-title">Balsam de buze natural si hidratant</h1>
      </div>
