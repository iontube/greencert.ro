---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat zgomot face o banda de alergat pentru apartament?", answer: "Nivelul de zgomot variaza mult in functie de model si calitatea constructiei. Benzile walking pad sunt cele mai silentioase. Modelele pliabile mai bine construite, cu amortizare buna, pot fi, de asemenea, destul de discrete. Este indicat sa verifici specificatiile si review-urile pentru a te orienta." },
    { question: "Pot alerga pe o banda pliabila sau doar sa merg?", answer: "Depinde de model. Benzile walking pad sunt create exclusiv pentru mers alert. Majoritatea benzilor pliabile compacte sunt potrivite pentru mers alert si alergare usoara. Pentru alergare mai serioasa, ai nevoie de o banda cu un motor mai puternic, o suprafata de alergare mai mare si o constructie mai solida." },
    { question: "Cat spatiu ocupa o banda de alergat pliabila?", answer: "Cand sunt pliate, multe modele compacte au o grosime de doar 20-30 cm, permitand depozitarea sub pat sau in spatele unei usi. Verifica dimensiunile exacte ale modelului care te intereseaza si masoara spatiul de depozitare." },
    { question: "Sunt benzile de alergat pentru apartament durabile?", answer: "Durabilitatea depinde de calitatea constructiei, de motor si de cat de des si intensiv este folosita. Un model mai scump, cu componente de calitate, va rezista mai mult decat unul foarte ieftin. Intretinerea corecta este, de asemenea, cruciala." },
    { question: "Ce fel de covor ar trebui sa folosesc sub banda de alergat?", answer: "Cel mai bine este sa folosesti un covor special pentru echipament fitness, fabricat din cauciuc dens. Acesta absoarbe vibratiile, reduce zgomotul si protejeaza atat banda, cat si podeaua ta." },
    { question: "Merita sa investesc intr-o banda de alergat pentru apartament daca am deja un abonament la sala?", answer: "Daca iti doresti flexibilitate si posibilitatea de a face miscare oricand, indiferent de vreme sau program, atunci da, merita. E o unealta complementara, utila mai ales in zilele in care nu poti ajunge la sala sau cand preferi confortul casei." }
];

const formattedDate = new Date("2026-01-12T06:00:00.000Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

