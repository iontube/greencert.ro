---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa spirulina in Romania?", answer: "Un pachet de spirulina pulbere de 200g incepe de la 40-50 lei pentru variantele non-bio si poate ajunge la peste 100-120 lei pentru cele certificate organic, din surse premium. Tabletele sau capsulele sunt in plaja de 35-90 lei pentru un flacon cu 100-200 bucati, in functie de brand si concentratie." },
    { question: "Spirulina te ajuta sa slabesti?", answer: "Spirulina nu este un produs de slabit minune, dar poate contribui la gestionarea greutatii prin faptul ca este bogata in proteine si fibre, oferind o senzatie de satietate mai indelungata. De asemenea, poate reduce pofta de mancare si sustine metabolismul, fiind un adjuvant intr-un regim alimentar echilibrat si un stil de viata activ." },
    { question: "Care sunt cele mai importante beneficii ale spirulinei?", answer: "Printre cele mai importante beneficii ale spirulinei se numara cresterea nivelului de energie, sustinerea sistemului imunitar, detoxifierea blanda a organismului, imbunatatirea digestiei si aportul bogat de proteine si fier. Este un superaliment complet, ideal pentru un boost nutritional general si pentru combaterea oboselii cronice." },
    { question: "Cine nu are voie sa ia spirulina? (Contraindicatii)", answer: "Spirulina este contraindicata persoanelor cu boli autoimune (lupus, artrita reumatoida), celor care iau medicamente anticoagulante din cauza continutului de vitamina K, femeilor insarcinate sau care alapteaza (fara aviz medical), si persoanelor cu fenilcetonurie. E bine sa consulti un medic inainte de a incepe orice supliment." },
    { question: "Cum se ia spirulina corect?", answer: "Spirulina se ia de obicei dimineata, pe stomacul gol, sau intre mese, cu un pahar mare de apa. Pentru pulbere, poti incepe cu 1-2 grame pe zi, crescand treptat pana la 3-5 grame, adaugand-o in smoothie-uri sau sucuri reci. Tabletele/capsulele se iau conform indicatiilor de pe ambalaj, de obicei 2-3 pe zi." },
    { question: "Spirulina are efecte adverse?", answer: "Da, spirulina poate avea efecte adverse, mai ales la inceput sau la doze mari. Acestea pot include greata, diaree, balonare, dureri de cap sau o usoara febra. Aceste simptome sunt adesea semnul unei detoxifieri initiale si se diminueaza pe masura ce corpul se adapteaza. E important sa incepi cu o doza mica si sa cresti treptat." },
    { question: "De unde cumpar spirulina de calitate in Romania?", answer: "Spirulina de calitate o gasesti in magazinele naturiste specializate (online si fizice), la plafaruri mari sau in farmacii care au sectiuni de suplimente. Cauta branduri cunoscute si cu reputatie buna, cum ar fi Bio Earth, Solaris, Pronatura, sau Pukka. Asigura-te ca produsul are certificare bio si o sursa clara de provenienta." },
    { question: "Care e diferenta intre spirulina pulbere si tablete?", answer: "Spirulina pulbere are avantajul unei absorbtii mai rapide si o versatilitate mai mare in utilizare (smoothie-uri, sucuri), dar are un gust puternic si necesita dozare. Tabletele sau capsulele sunt mai comode, fara gust, usor de transportat si de administrat, insa pot avea o absorbtie usor mai lenta si pot contine excipienti." }
];

const formattedDate = new Date("2026-02-09T15:10:01.822Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

