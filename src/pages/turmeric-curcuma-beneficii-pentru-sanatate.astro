---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Ce beneficii are turmericul pentru sanatate?", answer: "Turmericul are puternice proprietati antiinflamatorii si antioxidante, datorita curcuminei. Ajuta la reducerea durerilor articulare, imbunatateste digestia, sustine functia cerebrala si contribuie la intarirea sistemului imunitar. Studiile sugereaza ca poate reduce riscul unor boli cronice." },
    { question: "Cum se ia turmericul pentru o absorbtie maxima?", answer: "Pentru o absorbtie maxima, turmericul trebuie consumat impreuna cu piper negru. Piperina din piper negru creste biodisponibilitatea curcuminei cu pana la 2000%. De asemenea, consumul cu grasimi sanatoase (ulei de cocos, avocado) poate imbunatati absorbtia." },
    { question: "Exista contraindicatii sau efecte secundare la turmeric?", answer: "In general, turmericul este sigur, dar in doze mari poate provoca probleme digestive usoare (greata, diaree). Este contraindicat persoanelor cu calculi biliari, femeilor insarcinate sau care alapteaza, si celor care iau anticoagulante. Consulta medicul inainte de a incepe suplimentarea." },
    { question: "Care e diferenta intre turmeric pudra si supliment de curcuma?", answer: "Turmeric pudra este radacina uscata si macinata, cu o concentratie variabila de curcumina (de obicei 2-5%). Suplimentele de curcuma contin extracte standardizate, cu o concentratie mult mai mare de curcuminoide (frecvent 95%), fiind mult mai potente pentru efecte terapeutice specifice." },
    { question: "Cat costa un supliment bun cu turmeric si piper negru in Romania?", answer: "Un supliment bun cu turmeric si piper negru, cu 60 de capsule si o concentratie de 95% curcuminoide, costa in Romania intre 55 si 75 de lei. Pretul per capsula variaza de la ~0.9 lei la ~1.3 lei, in functie de brand si concentratie." }
];

const formattedDate = new Date("2026-03-06T10:53:18.824Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout
