---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Sunt detergentii ecologici mai scumpi decat cei clasici?", answer: "La prima vedere, pretul pe bidon poate fi mai mare. Insa, multi detergenti ecologici sunt mai concentrati, asa ca ai nevoie de o cantitate mai mica la fiecare spalare. Daca faci un calcul pe cost per spalare, diferentele nu sunt atat de mari, iar beneficiile pentru sanatate si mediu compenseaza adesea. Exista si optiuni foarte economice, precum nucile de sapun sau detergentul DIY." },
    { question: "Sunt detergentii ecologici la fel de eficienti ca cei clasici?", answer: "Da, pentru majoritatea spalarilor de zi cu zi, detergentii ecologici sunt la fel de eficienti. Pentru petele foarte dificile, s-ar putea sa ai nevoie de un pre-tratament cu produse naturale (sapun de Marsilia, bicarbonat). E o chestiune de adaptare si de a invata sa folosesti trucuri complementare pentru a obtine cele mai bune rezultate, fara chimicale dure." },
    { question: "Pot folosi detergenti ecologici pentru hainele de bebelusi?", answer: "Absolut! De fapt, sunt cea mai buna alegere pentru hainele de bebelusi. Pielea lor este extrem de sensibila, iar detergentii ecologici, in special cei marcati sensitive sau fara parfum, reduc riscul de iritatii, alergii si eruptii cutanate. Sunt formulati cu ingrediente blande, pe baza de plante, sigure pentru cei mici." },
    { question: "Ce fac cu petele dificile daca folosesc detergenti ecologici?", answer: "Pentru petele dificile, pre-tratamentul este esential. Aplica direct pe pata sapun de Marsilia solid, o pasta de bicarbonat de sodiu cu putin otet, sau peroxid de hidrogen diluat. Lasa sa actioneze cateva minute, apoi spala haina normal. Exista si solutii eco speciale pentru pete, cum ar fi cele pe baza de bila de bou sau enzime naturale." },
    { question: "De ce nu fac detergentii ecologici multa spuma?", answer: "Detergentii ecologici contin mai putini agenti de spumare artificiali. Spuma multa nu este un indicator al eficientei curatarii, ci mai degraba un efect vizual. Un detergent eco curata hainele in profunzime chiar si cu putina spuma, ceea ce este si mai bine pentru masina de spalat si pentru mediul acvatic, reducand reziduurile." },
    { question: "Cum stiu ca un detergent e cu adevarat ecologic?", answer: "Cauta certificari recunoscute, precum Ecocert, EU Ecolabel, Vegan Society. Acestea garanteaza ca produsul respecta standarde stricte. Verifica lista de ingrediente pentru a evita substante precum fosfati, clor, parabeni, parfumuri sintetice puternice. Un detergent cu adevarat ecologic va avea ingrediente pe baza de plante, biodegradabile si ambalaj reciclabil sau compostabil." }
];

const formattedDate = new Date("2026-01-25T18:08:04.000Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
