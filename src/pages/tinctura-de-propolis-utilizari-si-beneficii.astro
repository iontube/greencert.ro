    <section id="comparison" class="comparison-section">
      <h2>Tinctura de Propolis si Alternativele Sale: Un Tabel Comparativ pentru Utilizari si Beneficii</h2>
      <div class="comparison-scroll">
        <table class="comparison-table">
          <thead>
