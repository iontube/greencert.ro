          <tr><td>Propolis C Comprimate Masticabile Fiterman</td><td>Supliment alimentar</td><td>20 comprimate</td><td>Standarde Fiterman</td><td>Propolis, Vitamina C, menta</td><td>Calatorii, boost rapid imunitate, adulti</td></tr>
