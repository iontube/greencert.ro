          <tbody>
          <tr><td>Tinctura de Propolis 30% Apicola</td><td>Tinctura clasica</td><td>30ml</td><td>Calitate apicola</td><td>Propolis 30%, alcool 70%</td><td>Adulti, imunitate, gat iritat</td></tr>
          <tr><td>Tinctura de Propolis fara alcool Dacia Plant</td><td>Tinctura hidroglicerinica</td><td>50ml</td><td>Standarde Dacia Plant</td><td>Propolis, glicerina vegetala</td><td>Copii, adulti sensibili, fara alcool</td></tr>
          <tr><td>Spray de Gat Propolis si Miere Fares</td><td>Spray oral</td><td>20ml</td><td>Standarde Fares</td><td>Propolis, miere, menta, eucalipt</td><td>Ameliorare locala gat, adulti si copii</td></tr>
