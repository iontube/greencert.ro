---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa o tinctura de propolis buna?", answer: "O tinctura de propolis de calitate, de 30ml, costa in general intre 15 si 25 de lei. Preturile variaza in functie de concentratie si brand, dar o varianta de 30% propolis, de la un producator recunoscut, se incadreaza in acest interval." },
    { question: "Care e diferenta intre tinctura de propolis cu alcool si fara alcool?", answer: "Diferenta principala e solventul folosit. Cea cu alcool (hidroalcoolica) e mai eficienta in extragerea compusilor, dar nu e potrivita pentru copii sau cei care evita alcoolul. Varianta fara alcool (hidroglicerinica) foloseste glicerina vegetala, e mai blanda si potrivita pentru toate varstele, dar poate avea o absorbtie usor diferita." },
    { question: "Merita sa iau tinctura de propolis zilnic pentru imunitate?", answer: "Da, multi oameni o iau zilnic, in special in sezonul rece, pentru a-si intari imunitatea. Este considerata un imunostimulator natural. Recomandarea generala e sa faci cure de 2-3 saptamani, urmate de o pauza, sau sa o iei preventiv in doze mici. Discuta cu un specialist daca ai afectiuni cronice." },
    { question: "Cum se administreaza tinctura de propolis la copii?", answer: "Pentru copii, se recomanda exclusiv tinctura de propolis fara alcool. Doza uzuala este de 3-5 picaturi, de 2-3 ori pe zi, diluate intr-o lingurita de miere, apa sau ceai. E important sa consulti medicul pediatru inainte de a incepe orice tratament pentru copii, mai ales sub 3 ani." },
    { question: "Tinctura de propolis are efecte secundare?", answer: "In general, tinctura de propolis este bine tolerata, dar poate provoca reactii alergice la persoanele sensibile la produsele apicole (miere, polen). Simptomele pot include eruptii cutanate, mancarimi sau dificultati respiratorii. Daca apar astfel de reactii, intrerupe imediat utilizarea si consulta un medic." }
];

const formattedDate = new Date("2026-03-10T10:59:23.827Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout
