---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "cat costa o saltea de yoga buna?", answer: "O saltea de yoga buna, care sa ofere aderenta si durabilitate decente, costa de obicei intre 250 si 500 RON. Modelele premium, considerate cele mai bune saltele de yoga, pot ajunge la 600-800 RON, dar sunt o investitie pe termen lung, rezistand chiar si 5-10 ani." },
    { question: "care e diferenta intre saltea yoga si saltea fitness?", answer: "Salteaua de yoga este conceputa pentru aderenta si stabilitate in posturi statice, avand o grosime de 3-6mm. Salteaua de fitness este mai groasa (6-15mm) si mai moale, oferind amortizare pentru exercitii dinamice, sarituri sau Pilates, unde aderenta nu este la fel de critica." },
    { question: "merita sa investesc intr-o saltea yoga scumpa?", answer: "Da, merita sa investesti intr-o saltea yoga scumpa daca practici regulat si vrei aderenta, confort si durabilitate pe termen lung. O saltea de calitate superioara (peste 500 RON) iti va imbunatati semnificativ practica si te va scuti de inlocuiri frecvente, amortizandu-se in 2-3 ani." },
    { question: "ce grosime de saltea yoga e mai buna?", answer: "Pentru majoritatea practicantilor, o grosime de 4-5mm este considerata optima pentru cele mai bune saltele de yoga. Aceasta ofera un echilibru bun intre amortizarea articulatiilor si stabilitatea necesara pentru posturile de echilibru. Saltelele mai subtiri sunt pentru calatorii, iar cele mai groase pot fi instabile." },
    { question: "de ce imi aluneca mainile pe salteaua de yoga?", answer: "Mainile iti aluneca pe salteaua de yoga din mai multe motive: materialul saltelei este de proasta calitate si nu ofera aderenta (PVC ieftin), salteaua este noua si necesita \"rodaj\" (cazul Manduka), sau ai mainile transpirate si salteaua nu absoarbe umiditatea. Curatarea regulata si folosirea unui prosop de yoga pot ajuta." },
    { question: "cum sa curat o saltea de yoga ca sa nu se strice?", answer: "Pentru a curata o saltea de yoga fara sa o strici, foloseste un spray special pentru saltele sau o solutie DIY din apa si otet de mere (1:1) cu cateva picaturi de ulei esential. Sterge-o cu o carpa umeda dupa fiecare utilizare si las-o sa se usuce complet inainte de a o rula. Evita produsele chimice dure sau masina de spalat." },
    { question: "unde gasesc cele mai bune saltele de yoga online in romania?", answer: "Cele mai bune saltele de yoga online in Romania le gasesti pe site-uri specializate de yoga si fitness, cum ar fi YogaMarket.ro, Decathlon.ro, sau pe eMAG.ro, unde poti filtra dupa branduri precum Manduka, Liforme, Jade Yoga. Verifica si site-urile de importatori directi pentru preturi mai bune si oferte." },
    { question: "saltea yoga din cauciuc natural sau pvc, care e mai buna?", answer: "Salteaua din cauciuc natural este, in general, mai buna decat cea din PVC, oferind o aderenta superioara, mai ales cand e umeda, si fiind o optiune mai ecologica. PVC-ul de calitate (precum cel de la Manduka) poate fi extrem de durabil, dar PVC-ul ieftin este alunecos si mai putin prietenos cu mediul." }
];

const formattedDate = new Date("2026-02-20T15:10:01.865Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

