    <article class="product-review" id="product-3">
      <div class="product-header">
        <h2>Spirulina Tablete BIO Dragon Superfoods</h2>
        <span class="section-tag">~100 lei</span>
      </div>
      
        <div class="specs-grid">
          <div class="spec-item"><span class="spec-label">Tip</span><span class="spec-value">superaliment, supliment alimentar</span></div>
