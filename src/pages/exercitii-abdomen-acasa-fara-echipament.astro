    </article>

    <article class="product-review" id="product-5">
      <div class="product-header">
        <h2>Ulei de Cocos Extra Virgin BIO Dragon Superfoods</h2>
        <span class="section-tag">~40 lei</span>
      </div>
      
        <div class="specs-grid">
          <div class="spec-item"><span class="spec-label">Tip</span><span class="spec-value">aliment eco, ulei vegetal</span></div>
