---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cati ani trebuie sa am ca sa fac exercitii abdomen acasa?", answer: "Nu exista o varsta minima stricta, dar majoritatea programelor de exercitii abdomen acasa fara echipament sunt potrivite pentru adolescenti si adulti. Copiii pot face miscari de baza, dar fara a forta. Important este sa asculti corpul si sa adaptezi intensitatea." },
    { question: "Cat de des ar trebui sa fac exercitii pentru abdomen?", answer: "Ideal ar fi sa faci exercitii abdomen acasa fara echipament de 3-4 ori pe saptamana, lasand o zi de pauza intre antrenamente pentru recuperare musculara. Muschii abdominali, la fel ca oricare alt grup muscular, au nevoie de timp sa se refaca si sa creasca." },
    { question: "In cat timp se vad rezultate la exercitiile pentru abdomen?", answer: "Rezultatele pot varia, dar cu o dieta echilibrata si antrenament consistent de 3-4 ori pe saptamana, poti incepe sa vezi schimbari subtile in 4-6 saptamani. Pentru un abdomen vizibil tonifiat, e nevoie de 2-3 luni sau mai mult, depinzand de grasimea corporala initiala." },
    { question: "Ce exercitii sunt cele mai bune pentru abdomenul inferior?", answer: "Pentru abdomenul inferior, ridicarile de picioare, foarfecele (leg raises) si reverse crunches sunt super eficiente. Aceste exercitii abdomen acasa fara echipament lucreaza specific partea de jos a rectului abdominal, ajutand la tonifiere si definire." },
    { question: "Pot sa slabesc doar facand exercitii la abdomen?", answer: "Nu, nu poti slabi doar la abdomen (conceptul de \"slabire localizata\" e un mit). Exercitii abdomen acasa fara echipament tonifiaza muschii, dar pentru a reduce grasimea de pe abdomen e nevoie de un deficit caloric, adica sa mananci mai putin decat consumi, combinat cu exercitii cardio si o dieta sanatoasa. Un abdomen plat e 80% dieta si 20% exercitiu." }
];

const formattedDate = new Date("2026-03-12T11:00:29.240Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout
