          <tr><td>Domyos (Decathlon) Kit 20 kg</td><td>-</td><td>-</td><td>-</td><td>-</td><td>Incepatori, buget redus, antrenamente ocazionale</td></tr>
          <tr><td>Tunturi Selector Dumbbell 20 kg</td><td>-</td><td>-</td><td>-</td><td>-</td><td>Utilizatori intermediari, spatiu limitat, buget mediu</td></tr>
          <tr><td>PowerBlock Sport 24</td><td>-</td><td>-</td><td>-</td><td>-</td><td>Spatiu minim, durabilitate maxima, buget mare, antrenamente intense</td></tr>
          <tr><td>Gorilla Sports Set 20 kg</td><td>-</td><td>-</td><td>-</td><td>-</td><td>Incepatori, buget redus, antrenamente ocazionale, fara graba</td></tr>
          </tbody>
