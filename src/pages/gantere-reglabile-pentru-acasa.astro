---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa un set de gantere reglabile pentru acasa?", answer: "Un set de gantere reglabile pentru acasa poate costa de la aproximativ 300 lei pentru modelele clasice cu discuri si cleme, pana la peste 3000 lei pentru cele premium, cu mecanism de ajustare rapid, cum ar fi Bowflex sau PowerBlock. Pretul mediu pentru o pereche decenta, cu schimbare rapida, e in jur de 1500-2500 lei." },
    { question: "Care e diferenta intre gantere reglabile tip dial si cele cu pin?", answer: "Ganterele reglabile tip dial (ex: Bowflex) folosesc o rotita pentru a schimba rapid greutatea, fiind cele mai comode. Cele cu pin (ex: Tunturi, PowerBlock) au un pin pe care il glisezi sau il scoti pentru a selecta greutatea, fiind de obicei mai robuste si mai compacte, dar un pic mai lente decat cele dial." },
    { question: "Merita sa investesc in gantere reglabile scumpe?", answer: "Da, de cele mai multe ori merita investitia in gantere reglabile scumpe daca le folosesti regulat si iti doresti eficienta. Modelele premium ofera o schimbare rapida a greutatii, durabilitate superioara si un design compact, economisind spatiu si timp in comparatie cu multiple seturi de gantere fixe sau cu cele clasice, manuale." },
    { question: "Ce greutate maxima ar trebui sa aleg pentru gantere reglabile de acasa?", answer: "Greutatea maxima ideala pentru gantere reglabile de acasa depinde de nivelul tau de fitness si obiective. Pentru incepatori, un set care ajunge pana la 10-15 kg per gantera e suficient. Utilizatorii intermediari si avansati ar beneficia mai mult de seturi care ajung la 20-24 kg per gantera pentru a putea progresa si a lucra toti muschii eficient." },
    { question: "Cum sa intretin ganterele reglabile ca sa tina mai mult?", answer: "Pentru a intretine ganterele reglabile, curata-le periodic cu o carpa umeda pentru a indeparta transpiratia si praful. Evita sa le arunci pe jos, deoarece socurile pot deteriora mecanismul. Verifica suruburile sau sistemele de blocare ocazional pentru a te asigura ca sunt stranse si functioneaza corect. Pastreaza-le intr-un loc uscat, ferit de umiditate excesiva." }
];

const formattedDate = new Date("2026-03-07T10:42:14.102Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

