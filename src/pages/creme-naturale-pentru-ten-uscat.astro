---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Pot folosi creme naturale daca am pielea sensibila?", answer: "Da, chiar e recomandat. Cremele naturale contin adesea mai putine ingrediente iritante, cum ar fi parfumurile sintetice sau conservantii agresivi. Ingrediente precum ovazul coloidal, musetelul sau galbenelele sunt cunoscute pentru proprietatile lor calmante si sunt ideale pentru pielea sensibila. E important sa faci un test pe o zona mica, la fel ca la orice alt produs nou." },
    { question: "Cat de des ar trebui sa aplic o crema naturala pentru ten uscat?", answer: "Ideal ar fi sa aplici crema de doua ori pe zi, dimineata si seara, dupa curatarea tenului. Dimineata, crema va proteja pielea de factorii externi, iar seara va ajuta la regenerare si reparare pe timpul noptii. Daca simti ca tenul tau e foarte uscat, o poti aplica si pe parcursul zilei, in cantitati mici, pentru un plus de confort." },
    { question: "Ce ingrediente naturale ar trebui sa caut intr-o crema?", answer: "Cauta uleiuri vegetale hranitoare precum uleiul de jojoba, argan, avocado sau macese. Unturile vegetale (shea, cacao) sunt excelente pentru hidratare profunda. Ingrediente calmante ca extractul de galbenele, musetel sau ovazul coloidal sunt si ele de dorit. Glicerina vegetala si acidul hialuronic natural sunt umectanti eficienti care retin apa in piele." },
    { question: "Cum stiu daca o crema naturala e buna pentru tenul meu?", answer: "Cel mai bun mod e sa observi cum reactioneaza pielea ta. Dupa aplicare, ar trebui sa simti confort, hidratare si sa nu ai senzatie de strangere sau mancarime. Daca apar roseata, iritatii sau cosuri, probabil nu e potrivita. Fa intotdeauna un test pe o zona mica de piele (de exemplu, pe gat sau in spatele urechii) inainte de a aplica pe toata fata." },
    { question: "Cremele naturale expira mai repede?", answer: "In general, da. Deoarece contin mai putini conservanti sintetici, cremele naturale au o durata de viata mai scurta decat cele conventionale. Verifica intotdeauna data de expirare si simbolul PAO (Period After Opening) de pe ambalaj, care indica cate luni e valabil produsul dupa deschidere. Pastreaza-le intr-un loc racoros si intunecat pentru a le prelungi viata." },
    { question: "Pot inlocui crema de noapte cu un ulei natural?", answer: "Da, multe persoane o fac cu succes. Uleiurile pure precum cel de jojoba, argan sau squalane pot oferi o nutritie excelenta pe timpul noptii. Aplica cateva picaturi pe tenul curat si umed, masand usor. Totusi, daca ai tenul foarte deshidratat, o crema bogata care combina uleiuri cu umectanti si apa poate fi mai eficienta pentru a bloca hidratarea." }
];

const formattedDate = new Date("2026-01-21T15:51:33.000Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

