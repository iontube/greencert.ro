---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import fs from 'fs';
import path from 'path';

const keywordsPath = path.join(process.cwd(), 'keywords.json');
const keywordsData = JSON.parse(fs.readFileSync(keywordsPath, 'utf-8'));

const allArticles = keywordsData.completed.map((item) => {
  const articleSlug = item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  return {
    title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
    slug: articleSlug,
    excerpt: item.excerpt || '',
    image: `/images/articles/${articleSlug}.webp`,
    category: item.category,
    categorySlug: item.categorySlug,
    date: item.date
  };
});

const faq = [
    { question: "Cat costa semintele de chia in Romania?", answer: "Semintele de chia in Romania costa, in general, intre 15 lei si 35 lei pentru o punga de 500g. Preturile variaza in functie de certificarea bio, brand si magazin, cele bio fiind de obicei in intervalul 20-35 lei, iar cele non-bio mai aproape de 15-20 lei." },
    { question: "Ce diferenta e intre semintele de chia albe si negre?", answer: "Diferenta principala intre semintele de chia albe si negre este culoarea lor, profilul nutritional fiind aproape identic. Cele albe sunt preferate pentru preparate unde se doreste mentinerea unei culori deschise, iar cele negre sunt mai raspandite si adesea mai accesibile ca pret." },
    { question: "Merita sa cumpar seminte de chia bio?", answer: "Da, merita sa cumperi seminte de chia bio pentru a evita pesticidele si alte substante chimice folosite in agricultura conventionala. Certificarea ecologica ofera o garantie ca produsul este mai curat si respecta standarde stricte de cultivare, contribuind la o alimentatie mai sanatoasa." },
    { question: "Cum se pastreaza semintele de chia corect?", answer: "Semintele de chia trebuie pastrate intr-un recipient etans, intr-un loc racoros, intunecat si uscat, ferite de lumina directa a soarelui si umezeala. Ideal este sa le tii in camara sau in frigider, mai ales dupa deschiderea ambalajului, pentru a preveni rancezirea." },
    { question: "De ce se rancezesc semintele de chia?", answer: "Semintele de chia se rancezesc din cauza continutului lor ridicat de acizi grasi Omega-3, care sunt sensibili la oxidare in prezenta luminii, aerului si caldurii. Pastrarea incorecta, in ambalaje transparente sau in locuri calde, accelereaza acest proces, alterandu-le gustul si proprietatile." },
    { question: "Care sunt cele mai bune seminte de chia pentru budinca?", answer: "Pentru budinca, cele mai bune seminte de chia sunt cele bio, de la branduri precum SanoVita sau Solaris, care se hidrateaza uniform si formeaza un gel cremos, fara gusturi straine. Poti alege atat varianta alba, cat si cea neagra, in functie de preferintele estetice ale preparatului." },
    { question: "Unde gasesc seminte de chia de calitate in Romania?", answer: "Seminte de chia de calitate se gasesc in supermarketuri mari (Mega Image, Kaufland, Carrefour) la raioanele bio, in magazine naturiste specializate si in magazine online dedicate produselor sanatoase. Cauta branduri consacrate precum SanoVita Bio sau Solaris Bio." },
    { question: "Cum verific daca semintele de chia sunt proaspete?", answer: "Pentru a verifica prospetimea semintelor de chia, uita-te la data de expirare si, daca e disponibila, la data productiei. Semintele proaspete au un miros neutru si o textura ferma. Daca miros a ranced sau au un gust amarui, sunt vechi si nu ar trebui consumate." }
];

const formattedDate = new Date("2026-02-04T17:41:26.051Z").toLocaleDateString('ro-RO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

